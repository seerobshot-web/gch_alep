# Copy to infra/fossbilling/.env — NEVER commit the real .env.
# Generate passwords with: openssl rand -hex 24

# localhost = local fixture capture (plain HTTP on :80)
# billing.gloryhosts.cloud = production (Caddy auto-provisions TLS;
#   DNS A record for the domain must already point at this VPS)
BILLING_DOMAIN=localhost

MYSQL_DATABASE=fossbilling
MYSQL_USER=fossbilling
MYSQL_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme
